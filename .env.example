# ── Xyron Codex Python — Environment Config ──────────────────────────────────────
# Copy ke .env dan isi minimal 1 API key.
# Auto-detection priority: groq > openrouter > gemini > cerebras > mistral > xai > kimi > qwen > sambanova > together > minimax > nvidia > copilot
#
# ╔══════════════════════════════════════════════════════════════╗
# ║  GRATIS TANPA API KEY? Set: XYRON_PROVIDER=copilot          ║
# ║  Pakai: https://xyron-rest-api.vercel.app/ai/copilot        ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Provider Selection ─────────────────────────────────────────────────────────
# Default: auto (deteksi dari key yang tersedia, fallback ke copilot jika kosong)
# Opsi: auto | copilot | groq | openrouter | gemini | deepseek | cerebras | ...
XYRON_PROVIDER=auto

# ── Model Override ─────────────────────────────────────────────────────────────
# Default: auto (pakai default model provider)
XYRON_DEFAULT_MODEL=auto

# ── Behavior ───────────────────────────────────────────────────────────────────
XYRON_MAX_CONTEXT_TOKENS=120000
XYRON_MAX_RESPONSE_TOKENS=8000
XYRON_TEMPERATURE=0.7
XYRON_PERMISSION_MODE=default

# ── API Keys — FAST / FREE ─────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
DEEPSEEK_API_KEY=sk-...
CEREBRAS_API_KEY=csk-...
SAMBANOVA_API_KEY=

# ── API Keys — FREE CREDITS ────────────────────────────────────────────────────
XAI_API_KEY=
TOGETHER_API_KEY=
KIMI_API_KEY=
QWEN_API_KEY=
QWEN_REGION=sg

# ── API Keys — ONGOING FREE TIER ──────────────────────────────────────────────
GEMINI_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_NIM_API_KEY=
MINIMAX_API_KEY=

# ── Web Search (optional) ──────────────────────────────────────────────────────
# Tavily — 1000 searches/month free, no CC required
# https://app.tavily.com
TAVILY_API_KEY=tvly-...
